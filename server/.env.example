# Server
NODE_ENV=production
PORT=3001

# Database (PostgreSQL connection string)
DATABASE_URL=

# Redis
REDIS_URL=

# JWT — use long random strings (min 32 chars)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel frontend URL after deploy
CORS_ORIGIN=

# Sentry (optional)
SENTRY_DSN=
